{
  "name": "hello-world",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:resources": "bun run scripts/build-resources.ts",
    "run": "bun run build && bun run build:resources && gjs -m scripts/launcher.mjs",
    "start": "bun run run",
    "dev": "bun run scripts/dev.ts",
    "setup": "meson setup _build --prefix=$HOME/.local",
    "install-app": "bun run build && meson compile -C _build && meson install -C _build",
    "clean": "rm -rf dist build _build"
  },
  "devDependencies": {
    "@girs/adw-1": "^1.10.0-4.0.4",
    "@girs/gdk-4.0": "^4.0.0-4.0.4",
    "@girs/gio-2.0": "^2.88.0-4.0.4",
    "@girs/glib-2.0": "^2.88.0-4.0.4",
    "@girs/gobject-2.0": "^2.88.0-4.0.4",
    "@girs/gtk-4.0": "^4.23.0-4.0.4",
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  }
}
